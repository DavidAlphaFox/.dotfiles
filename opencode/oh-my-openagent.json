{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "thinking": {
        "type": "enabled"
      },
      "compaction": {
        "model": "zhipuai-coding-plan/glm-4.7"
      }
    },
    "hephaestus": {
      "model": "kimi-for-coding/k3"
    },
    "oracle": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "maxTokens": 32768
    },
    "librarian": {
      "model": "minimax-cn-coding-plan/MiniMax-M3"
    },
    "explore": {
      "model": "minimax-cn-coding-plan/MiniMax-M3"
    },
    "multimodal-looker": {
      "model": "kimi-for-coding/k2p7",
      "maxTokens": 16384
    },
    "prometheus": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "maxTokens": 16384
    },
    "metis": {
      "model": "kimi-for-coding/k3"
    },
    "momus": {
      "model": "kimi-for-coding/k3"
    },
    "atlas": {
      "model": "zhipuai-coding-plan/glm-5.2"
    },
    "sisyphus-junior": {
      "model": "kimi-for-coding/k2p7"
    }

  },
  "categories": {
    "visual-engineering": {
      "model": "kimi-for-coding/k3",
      "reasoningEffort": "high",
      "temperature": 0.7
    },
    "ultrabrain": {
      "model": "zhipuai-coding-plan/glm-5.2",
      "thinking": {
        "type": "enabled"
      },
      "reasoningEffort": "high"
    },
    "deep": {
      "model": "kimi-for-coding/k3",
      "reasoningEffort": "high"
    },
    "artistry": {
      "model": "kimi-for-coding/k3",
      "reasoningEffort": "high",
      "temperature": 0.9
    },
    "quick": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7",
      "temperature": 0.3
    },
    "unspecified-low": {
      "model": "minimax-cn-coding-plan/MiniMax-M3"
    },
    "unspecified-high": {
      "model": "kimi-for-coding/k3",
      "reasoningEffort": "high"
    },
    "writing": {
      "model": "minimax-cn-coding-plan/MiniMax-M3",
      "temperature": 0.6
    }
  }
}
